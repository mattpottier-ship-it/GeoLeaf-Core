{
    "name": "@geoleaf/core",
    "version": "1.1.0",
    "description": "GeoLeaf — Modular JavaScript mapping library built on Leaflet. v1.1: Full ESM migration, tree-shaking, selective imports. Features: Security (XSS protection), Performance (optimized build pipeline), Typed Errors, Validators, and comprehensive TypeScript support.",
    "type": "module",
    "main": "dist/geoleaf.umd.js",
    "module": "dist/geoleaf.esm.js",
    "unpkg": "dist/geoleaf.min.js",
    "jsdelivr": "dist/geoleaf.min.js",
    "types": "dist/types/bundle-esm-entry.d.ts",
    "browser": "dist/geoleaf.umd.js",
    "exports": {
        ".": {
            "import": "./dist/esm/bundle-esm-entry.js",
            "require": "./dist/geoleaf.umd.js",
            "types": "./dist/types/bundle-esm-entry.d.ts",
            "browser": "./dist/geoleaf.esm.js"
        }
    },
    "sideEffects": [
        "src/modules/globals.ts",
        "src/modules/globals.core.ts",
        "src/modules/globals.config.ts",
        "src/modules/globals.geojson.ts",
        "src/modules/globals.ui.ts",
        "src/modules/globals.poi.ts",
        "src/modules/globals.api.ts",
        "src/modules/geoleaf.api.ts",
        "src/modules/config/geoleaf-config/*.ts",
        "src/app/helpers.ts",
        "src/app/init.ts",
        "src/app/boot.ts",
        "src/app/init-feature-modules.ts",
        "src/lazy/*.ts",
        "src/bundle-entry.ts",
        "src/bundle-esm-entry.ts",
        "**/*.css"
    ],
    "scripts": {
        "build": "rollup -c && tsc --emitDeclarationOnly && npm run build:css",
        "build:watch": "rollup -c -w",
        "clean": "rimraf dist",
        "test": "node ../../scripts/smoke-test.cjs",
        "test:jest": "jest --config jest.config.cjs",
        "test:coverage": "jest --config jest.config.cjs --coverage --coverageDirectory=coverage",
        "test:coverage:phase14": "npm run test:coverage && node scripts/check-coverage-per-file.cjs",
        "test:coverage:70": "npm run test:coverage && node scripts/check-coverage-70.cjs",
        "check-coverage:70": "node scripts/check-coverage-70.cjs",
        "test:ci": "npm run test:coverage",
        "lint": "eslint src --ext .ts,.js",
        "lint:fix": "eslint src --ext .ts,.js --fix",
        "format": "prettier --write \"src/**/*.{ts,js}\" \"*.{json,md}\"",
        "build:css": "postcss src/css/geoleaf-main.css -o dist/geoleaf-main.min.css --map",
        "build:all": "npm run clean && npm run build && npm run build:css",
        "typecheck": "tsc --noEmit",
        "docs:api": "typedoc --options typedoc.json",
        "dead-code": "knip --no-progress"
    },
    "peerDependencies": {
        "@maplibre/maplibre-gl-leaflet": "^0.1.3",
        "leaflet": "^1.9.4",
        "leaflet.markercluster": "^1.5.3",
        "leaflet.vectorgrid": "^1.3.0",
        "maplibre-gl": "^5.0.0"
    },
    "peerDependenciesMeta": {
        "leaflet.vectorgrid": {
            "optional": true
        },
        "maplibre-gl": {
            "optional": true
        },
        "@maplibre/maplibre-gl-leaflet": {
            "optional": true
        }
    },
    "devDependencies": {
        "@rollup/plugin-alias": "^6.0.0",
        "@rollup/plugin-commonjs": "^29.0.0",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-replace": "^6.0.3",
        "rollup-plugin-esbuild": "^6.2.1",
        "@rollup/plugin-typescript": "^12.3.0",
        "@testing-library/dom": "^10.4.0",
        "@testing-library/jest-dom": "^6.4.2",
        "@types/jest": "^29.5.12",
        "cssnano": "^7.1.2",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-security": "^3.0.1",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "postcss": "^8.5.6",
        "postcss-cli": "^11.0.1",
        "postcss-import": "^16.1.1",
        "prettier": "^3.2.5",
        "rimraf": "^5.0.5",
        "rollup": "^4.12.0",
        "rollup-plugin-visualizer": "^6.0.5",
        "ts-jest": "^29.4.6",
        "tslib": "^2.8.1",
        "typedoc": "^0.26.11",
        "typescript": "^5.9.3"
    },
    "files": [
        "dist/",
        "README.md",
        "docs/"
    ],
    "keywords": [
        "leaflet",
        "map",
        "mapping",
        "gis",
        "geospatial",
        "frontend",
        "geoleaf",
        "geojson",
        "gpx",
        "security",
        "xss-protection",
        "typescript",
        "performance"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/mattpottier-ship-it/GeoLeaf-Core.git"
    },
    "bugs": {
        "url": "https://github.com/mattpottier-ship-it/GeoLeaf-Core/issues"
    },
    "homepage": "https://geoleaf.dev",
    "author": "GeoLeaf Project",
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    }
}
